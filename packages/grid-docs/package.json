{
  "name": "@jsoc/grid-docs",
  "version": "0.0.1",
  "description": "Utilities for the JSOC Grid documentation website.",
  "keywords": [
    "jsoc",
    "grid",
    "docs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsoc-dev/grid.git",
    "directory": "packages/grid-docs"
  },
  "bugs": {
    "url": "https://github.com/jsoc-dev/grid/issues"
  },
  "homepage": "https://github.com/jsoc-dev/grid/tree/main/packages/grid-docs#readme",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -w build-packages",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jsoc/utils": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
