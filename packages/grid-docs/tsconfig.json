{
  "compilerOptions": {
    // language
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,

    // type checking
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,

    // output
    "noEmit": true
  },

  "include": ["src"]
}
