{
  "name": "@jsoc/vue-grid",
  "version": "0.0.1",
  "description": "Dynamic columns/rows generator for popular Vue grid components",
  "keywords": [
    "datagrid",
    "datatable",
    "grid",
    "jsongrid",
    "vue",
    "table"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsoc-dev/grid.git",
    "directory": "packages/vue-grid"
  },
  "bugs": {
    "url": "https://github.com/jsoc-dev/grid/issues"
  },
  "homepage": "https://github.com/jsoc-dev/grid/tree/main/packages/vue-grid#readme",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -w build-packages",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@jsoc/grid-core": "workspace:*",
    "@jsoc/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vue/runtime-core": "^3.5.13",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "^7.2.0",
    "vue": "^3.5.13",
    "vue-tsc": "~3.2.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
