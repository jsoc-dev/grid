{
  "name": "@jsoc/grid-tanstack-shared",
  "version": "0.0.0",
  "description": "Shared TanStack Table column definitions (host-agnostic)",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -w build-packages",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^25.5.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@jsoc/grid-core": "workspace:*",
    "@jsoc/utils": "workspace:*",
    "@tanstack/table-core": "^8.21.3"
  }
}
