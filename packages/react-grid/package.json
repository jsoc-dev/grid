{
  "name": "@jsoc/react-grid",
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mui": {
      "types": "./dist/mui/index.d.ts",
      "import": "./dist/mui/index.js"
    },
    "./ag": {
      "types": "./dist/ag/index.d.ts",
      "import": "./dist/ag/index.js"
    },
    "./ant": {
      "types": "./dist/ant/index.d.ts",
      "import": "./dist/ant/index.js"
    },
    "./mantine": {
      "types": "./dist/mantine/index.d.ts",
      "import": "./dist/mantine/index.js"
    },
    "./prime": {
      "types": "./dist/prime/index.d.ts",
      "import": "./dist/prime/index.js"
    },
    "./tanstack": {
      "types": "./dist/tanstack/index.d.ts",
      "import": "./dist/tanstack/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "type": "tsc --noEmit",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "prepublishOnly": "pnpm run build && pnpm run test && pnpm run type"
  },
  "dependencies": {
    "@jsoc/grid-core": "workspace:*",
    "@jsoc/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@mui/x-data-grid": "^8.16.0",
    "@tanstack/react-table": "^8.21.3",
    "ag-grid-community": "^34.0.0 || ^35.0.0",
    "ag-grid-react": "^34.0.0 || ^35.0.0",
    "antd": "^6.3.5",
    "mantine-react-table": "^1.3.4",
    "primereact": "^10.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@mui/x-data-grid": {
      "optional": true
    },
    "@tanstack/react-table": {
      "optional": true
    },
    "antd": {
      "optional": true
    },
    "ag-grid-react": {
      "optional": true
    },
    "ag-grid-community": {
      "optional": true
    },
    "mantine-react-table": {
      "optional": true
    },
    "primereact": {
      "optional": true
    }
  }
}
