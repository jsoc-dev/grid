{
  "name": "@jsoc/react-grid",
  "version": "0.0.2",
  "description": "Dynamic columns/rows generator for popular React grid components",
  "keywords": [
    "datagrid",
    "datatable",
    "grid",
    "jsongrid",
    "react",
    "table"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsoc-dev/grid.git",
    "directory": "packages/react-grid"
  },
  "bugs": {
    "url": "https://github.com/jsoc-dev/grid/issues"
  },
  "homepage": "https://github.com/jsoc-dev/grid/tree/main/packages/react-grid#readme",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -w build-packages",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jsoc/grid-core": "workspace:*",
    "@jsoc/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
