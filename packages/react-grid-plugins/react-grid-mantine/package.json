{
  "name": "@jsoc/react-grid-mantine",
  "version": "0.0.0",
  "description": "Dynamic columns/rows generator for mantine React grid component",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -w build-packages",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jsoc/grid-core": "workspace:*",
    "@jsoc/utils": "workspace:*",
    "@jsoc/react-grid": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "mantine-react-table": "^1.3.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "mantine-react-table": "^1.3.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
