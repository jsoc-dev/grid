{
  "compilerOptions": {
    // target
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2024", "DOM"],

    "allowImportingTsExtensions": true, // subpath imports require file extensions

    // type checking
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,

    // output
    "noEmit": true // bundler will be used to emit
  },

  "include": ["src"]
}
