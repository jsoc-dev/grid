{
  "name": "@jsoc/grid",
  "private": true,
  "type": "module",
  "bin": {
    "build-packages": "scripts/build-packages.mjs"
  },
  "imports": {
    "#*": "./*"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "dependencies": {
    "@jsoc/grid-docs": "workspace:*",
    "@jsoc/utils": "workspace:*",
    "inquirer": "^13.4.2",
    "tsdown": "catalog:",
    "tsx": "^4.21.0",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "catalog:",
    "typescript-eslint": "^8.57.1"
  },
  "scripts": {
    "build-examples": "tsx scripts/build-examples.ts",
    "build-examples:manual": "tsx scripts/build-examples.ts manual",
    "build-packages": "tsx scripts/build-packages.ts",
    "build": "pnpm build-examples && pnpm build-packages",
    "changeset": "changeset",
    "commitlint": "commitlint",
    "lint": "eslint . && pnpm --recursive --parallel run lint",
    "lint:fix": "eslint . --fix && pnpm --recursive --parallel run lint:fix",
    "prepare": "husky",
    "release": "pnpm build && changeset publish",
    "typecheck": "tsc && pnpm --recursive --parallel run typecheck",
    "version-packages": "changeset version"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": "prettier --write"
  }
}
